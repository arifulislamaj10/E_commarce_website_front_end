# Base URL of the VelouraX backend API
NEXT_PUBLIC_API_URL=https://travel.sobhoy.com/api

# NEXT_PUBLIC_API_URL=https://travel_agency_back.sobhoy.com
# Hero background media (optional). The hero ships with a premium animated
# boutique image by default. To use YOUR OWN, drop a file in `frontend/public/`
# and set ONE of these:
#   NEXT_PUBLIC_HERO_VIDEO=/hero.mp4   (background video — looping, muted)
#   NEXT_PUBLIC_HERO_IMAGE=/hero.jpg   (background image — animated Ken Burns zoom)
# NEXT_PUBLIC_HERO_VIDEO=/hero.mp4
# NEXT_PUBLIC_HERO_IMAGE=/hero.jpg
